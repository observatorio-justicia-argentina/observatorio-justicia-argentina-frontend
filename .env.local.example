# ── API del backend ───────────────────────────────────────────────────────────
# En desarrollo apunta al backend local; en Vercel configurá la variable de entorno
# con la URL de Render (sin barra al final).
#
# Vercel dashboard → Settings → Environment Variables:
#   NEXT_PUBLIC_API_URL = https://observatorio-justicia-argentina-backend.onrender.com/api
#
NEXT_PUBLIC_API_URL=http://localhost:3600/api
